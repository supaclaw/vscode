{
  "name": "@supaclow/openclaw-vscode",
  "version": "1.0.0",
  "description": "VS Code channel plugin for OpenClaw that delivers outbound messages over HTTP.",
  "license": "MIT",
  "main": "index.js",
  "files": [
    "index.js",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"console.log('No build step required for this plugin.')\"",
    "test": "node --test"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "channel",
    "communication"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "vscode",
      "label": "VS Code Channel",
      "selectionLabel": "VS Code Channel (HTTP API)",
      "docsPath": "/channels/vscode",
      "docsLabel": "vscode",
      "blurb": "Connect OpenClaw to the VS Code channel over HTTP for outbound message delivery.",
      "order": 90,
      "aliases": [
        "vscode",
        "http-bridge"
      ]
    },
    "install": {
      "npmSpec": "@supaclow/openclaw-vscode",
      "defaultChoice": "npm"
    }
  }
}
